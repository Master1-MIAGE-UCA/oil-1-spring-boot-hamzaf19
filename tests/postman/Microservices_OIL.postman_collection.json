        {
          "name": "Scenario - Cycle de vie complet d'une partie",
          "item": [
            {
              "name": "1) Create Player for Scenario",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "pm.collectionVariables.set('scenario_player_pseudo', 'Scenario-' + Date.now());"
                    ],
                    "type": "text/javascript"
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const body = pm.response.json();",
                      "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                      "pm.collectionVariables.set('current_player_id', body.id);",
                      "pm.collectionVariables.set('current_player_initial_score', body.score);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"pseudo\": \"{{scenario_player_pseudo}}\",\n  \"score\": 0\n}"
                },
                "url": "{{url_player}}/api/players"
              }
            },
            {
              "name": "2) Start Game with current_player_id",
              "request": {
                "method": "POST",
                "header": [],
                "url": "{{url_game}}/api/games/start/{{current_player_id}}?nb=2"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const body = pm.response.json();",
                      "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                      "pm.test('At least one question', function () { pm.expect(body.questions.length).to.be.above(0); });"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "3) End Game with current_player_id",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"playerId\": {{current_player_id}},\n  \"score\": 50\n}"
                },
                "url": "{{url_game}}/api/games/end"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "4) Verify Player Score Increased",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{url_player}}/api/players/{{current_player_id}}"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const body = pm.response.json();",
                      "const initial = Number(pm.collectionVariables.get('current_player_initial_score') || 0);",
                      "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                      "pm.test('Score increased by 50', function () { pm.expect(body.score).to.eql(initial + 50); });"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        }
