      "name": "01. Player Service",
      "item": [
        {
          "name": "GET All Players - 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{url_player}}/api/players"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response < 500ms', function () { pm.expect(pm.response.responseTime).to.be.below(500); });",
                  "pm.test('Content-Type JSON', function () { pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'); });",
                  "pm.test('Body is array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
